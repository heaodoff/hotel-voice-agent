# === DOMAIN ===
DOMAIN=voice.yourdomain.com

# === DATABASE ===
POSTGRES_USER=voiceagent
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=hotel_voice_agent

# === APP ===
LOG_LEVEL=info
VALIDATE_TWILIO_SIGNATURE=true
RATE_LIMIT_WEBHOOK_RPM=120
RATE_LIMIT_API_RPM=60

# === TWILIO ===
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15075411684
TWILIO_WEBHOOK_BASE_URL=https://voice.yourdomain.com

# === OPENAI ===
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# === HOTEL ===
DEFAULT_HOTEL_ID=hotel_001
DEFAULT_HOTEL_NAME=Grand Plaza Hotel
DEFAULT_HOTEL_TIMEZONE=America/New_York
DEFAULT_HOTEL_PHONE=+1234567890

# === HANDOFF ===
HANDOFF_PHONE_NUMBER=+1234567891

# === NOTIFICATIONS ===
EMAIL_FROM=reservations@yourdomain.com
