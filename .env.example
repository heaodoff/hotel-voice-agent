# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hotel_voice_agent?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
# URL where Twilio can reach this server (use ngrok for local dev)
TWILIO_WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok-free.app

# Telnyx (optional — for European/Spanish numbers)
# TELNYX_API_KEY=KEYxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OpenAI Realtime model
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# Notifications
# SMS is sent via Twilio (uses same credentials above)
# Email provider (stub for MVP)
EMAIL_FROM=reservations@hotel.example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Hotel config (MVP single hotel)
DEFAULT_HOTEL_ID=hotel_001
DEFAULT_HOTEL_NAME=Grand Plaza Hotel
DEFAULT_HOTEL_TIMEZONE=America/New_York
DEFAULT_HOTEL_PHONE=+1234567890

# Human handoff
HANDOFF_PHONE_NUMBER=+1234567891

# Security (enable in production)
# ADMIN_API_KEY=your-secret-api-key-min-16-chars
VALIDATE_TWILIO_SIGNATURE=false
RATE_LIMIT_WEBHOOK_RPM=120
RATE_LIMIT_API_RPM=60
