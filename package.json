    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "twilio": "^5.4.3",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^4.1.0",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
